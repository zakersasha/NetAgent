# Скопировать: cp .env.example .env

# Telegram
TELEGRAM_BOT_TOKEN=
BOT_PROXY_URL=http://user:pass@45.93.137.80:3128
BOT_PROXY_URL_2=

# OpenAI (чат в боте)
OPENAI_API_KEY=
OPENAI_API_KEY_2=
OPENAI_MODEL=gpt-4o-mini
OPENAI_PROXY_URL=
OPENAI_PROXY_URL_2=
AI_FREE_DAILY_LIMIT=3
AI_SYSTEM_PROMPT=Ты полезный AI-ассистент в Telegram. Отвечай коротко, по делу, на русском.

BOT_SERVICE_NAME=NetAgent
TELEGRAM_BOT_USERNAME=
# Тот же токен, что для бота — нужен для ответов поддержки из админки
TELEGRAM_BOT_TOKEN=
COMPANY_EMAIL=support@netagent.ru
WEB_SECRET_KEY=change-me-generate-long-random-string
WEB_PORT=8001
WEB_HOST=0.0.0.0
BOT_SUPPORT_CONTACT=@sashakharlamov
# Telegram user id для оповещений о тикетах (узнать: @userinfobot)
SUPPORT_NOTIFY_TELEGRAM_ID=
TIMEZONE=Europe/Moscow
XRAY_PUBLIC_HOST=45.93.137.80
XRAY_PUBLIC_PORT=443
PAYMENT_PROVIDER=mock
# При PAYMENT_PROVIDER=yookassa: кнопка «Тест без оплаты» в боте (для проверки нод и т.п.)
ALLOW_MOCK_PAYMENT=false
# ЮKassa (PAYMENT_PROVIDER=yookassa)
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
# HTTPS-URL возврата после оплаты, напр. https://your-domain/cabinet?paid=1
YOOKASSA_RETURN_URL=

# PostgreSQL (единая БД для бота и будущей админки)
POSTGRES_USER=netagent
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=netagent
# Внешний порт на сервере (5432 или нестандартный, напр. 15432 — меньше сканеров)
POSTGRES_PORT=5432
# Для бота в Docker host = postgres
DATABASE_URL=postgresql+psycopg://netagent:change-me-strong-password@postgres:5432/netagent

# Админ (seed при первом запуске бота)
ADMIN_SEED_EMAIL=adkharlamov.dev@gmail.com
ADMIN_SEED_PASSWORD=

# Reality
REALITY_PUBLIC_KEY=YTQ_dIa_739_d6x7OUAd3XjMbpX3UOnWBMkGVtEhi18
REALITY_SHORT_ID=6ba85179e30d4fc2
REALITY_SNI=www.wikipedia.org
VLESS_FLOW=xtls-rprx-vision

# Xray Agent (Литва)
XRAY_AGENT_URL=https://45.93.137.80:8443
XRAY_AGENT_API_KEY=
XRAY_AGENT_VERIFY_SSL=false
XRAY_AGENT_TIMEOUT_SECONDS=60

# Device monitor (контроль 1 UUID = 1 устройство)
DEVICE_MONITOR_INTERVAL_SECONDS=30
DEVICE_MONITOR_MAX_ONLINE_IPS=1
GEOIP_DATABASE_PATH=

# Бэкап PostgreSQL → Яндекс.Диск (сервис db-backup)
BACKUP_ENABLED=true
BACKUP_HOUR=22
BACKUP_MINUTE=0
BACKUP_RETENTION_COUNT=10
BACKUP_POSTGRES_HOST=postgres
BACKUP_POSTGRES_PORT=5432
YANDEX_DISK_CLIENT_ID=
YANDEX_DISK_CLIENT_SECRET=
# Получить один раз: python -m db_backup.oauth_setup
YANDEX_DISK_REFRESH_TOKEN=
YANDEX_DISK_BACKUP_PATH=/NetAgent/backups
